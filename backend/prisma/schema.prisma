generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  ON_DUTY
  ON_TRIP
  SUSPENDED
  OFF_DUTY
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  DISPATCHER
  SAFETY
  FINANCE
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             UserRole
  refreshTokenHash String?  // hashed refresh token for rotation
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Vehicle {
  id              String           @id @default(uuid())
  name            String
  model           String
  licensePlate    String           @unique
  maxCapacityKg   Float
  odometer        Float
  acquisitionCost Float
  status          VehicleStatus    @default(AVAILABLE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]

  @@index([status, createdAt])
  @@index([licensePlate])
}

model Driver {
  id              String       @id @default(uuid())
  name            String
  licenseNumber   String
  licenseCategory String
  licenseExpiry   DateTime
  status          DriverStatus @default(OFF_DUTY)
  safetyScore     Float
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  trips           Trip[]

  @@index([status, createdAt])
  @@index([licenseExpiry])
}

model Trip {
  id            String     @id @default(uuid())
  vehicleId     String
  driverId      String
  cargoWeight   Float
  origin        String
  destination   String
  revenue       Float      @default(0)
  startOdometer Float
  endOdometer   Float?
  distanceKm    Float?
  status        TripStatus @default(DRAFT)
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
  updatedAt     DateTime   @updatedAt

  vehicle Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver  Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  fuelLog FuelLog[]

  @@index([status, createdAt])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  type        String
  cost        Float
  description String
  serviceDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  trip    Trip?   @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userRole  String?
  action    String   // e.g. RBAC_DENIAL, LOGIN_FAILED, TRIP_CREATED
  resource  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
